*~

# Runtime state — generated on the board, never committed:
#   - per-board calibration values (camera, HSV, geometry)
#   - per-deployment IoTConnect credentials
#   - launcher logs
#   - on-device model weights downloaded by get_model.sh
ball_color.json
box_color.json
box_pose.json
drop_pose.json
scan_poses.json
camera_settings.json
cam_gripper_offset.json
iotcDeviceConfig.json
device-cert.pem
device-pkey.pem
